# ColabFit MCP Environment Configuration

# ============================================================================
# DATA DIRECTORY (HOST PATH - where models and datasets are stored)
# ============================================================================
# Default: ./colabfit_data (relative to compose.yaml)
# Uncomment and customize to use a different location:
#   - Linux absolute path:   COLABFIT_DATA_ROOT=/home/username/my_ml_data
#   - macOS absolute path:   COLABFIT_DATA_ROOT=/Users/username/my_ml_data
#   - Windows (WSL2/Git Bash): COLABFIT_DATA_ROOT=/mnt/c/Users/username/colabfit_data
#   - Different relative path: COLABFIT_DATA_ROOT=../shared_data
#
# Models will be stored in: ${COLABFIT_DATA_ROOT}/models
# Datasets will be stored in: ${COLABFIT_DATA_ROOT}/datasets
#COLABFIT_DATA_ROOT=./colabfit_data

# ============================================================================
# USER/GROUP MAPPING (fixes Docker permission issues)
# ============================================================================
# Set these to match your host user ID to avoid permission issues with bind mounts.
# Linux/macOS: run `id -u` (USER_ID) and `id -g` (GROUP_ID) in a terminal.
# Windows (WSL2): run `id -u` and `id -g` inside the WSL2 terminal.
# Windows (Docker Desktop without WSL2): leave commented — defaults to 1000.
# Default: 1000 (common for first user on Linux systems)
#USER_ID=1000
#GROUP_ID=1000


# ============================================================================
# HUGGINGFACE TOKEN (optional but recommended)
# ============================================================================
# Avoids rate-limit warnings from HuggingFace Hub during dataset downloads.
# Get a free token at https://huggingface.co/settings/tokens (read-only is fine)
# HF_TOKEN=hf_...

# ============================================================================
# COLABFIT API CONFIGURATION
# ============================================================================
COLABFIT_BASE_URL=https://materials.colabfit.org
COLABFIT_AUTH_USER=mcp-tool
COLABFIT_AUTH_PASS=mcp-secret

# ============================================================================
# TRAINING PERFORMANCE
# ============================================================================
# Precision: float32 (fast, recommended for consumer GPUs) or float64 (slow, higher precision)
# Consumer GPUs (RTX 3060/4090 etc.) have ~1/32 float64 throughput vs float32 — use float32
# for training and float64 only if you need geometry optimization or high numerical precision
KLIFF_DTYPE=float32

# Batch size: increase for larger GPUs, decrease if you get OOM errors
# KLIFF_BATCH_SIZE=4

# Data loading workers: 0 disables multiprocessing (safe default), 2-4 for faster loading
# KLIFF_NUM_WORKERS=0